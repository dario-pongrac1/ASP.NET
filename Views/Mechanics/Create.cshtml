@model Mechanic
@{
    ViewData["Title"] = "Novi mehaničar";
}

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Početna</a>
    <span>/</span>
    <a asp-controller="Mechanics" asp-action="Index">Mehaničari</a>
    <span>/</span>
    <span>Novi mehaničar</span>
</nav>

<section class="page-header">
    <h1>Novi mehaničar</h1>
</section>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Specialty"></label>
            <input asp-for="Specialty" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="IsCertified"></label>
            <input asp-for="IsCertified" type="checkbox" />
        </div>
        <div class="mb-3">
            <label asp-for="ExperienceYears"></label>
            <input asp-for="ExperienceYears" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="HourlyRate"></label>
            <input asp-for="HourlyRate" class="form-control" type="number" step="0.01" />
        </div>
        <div class="mb-3">
            <label asp-for="EmployedSince"></label>
            @{
                ViewBag.InputId = "EmployedSince";
                ViewBag.InputName = "EmployedSince";
                ViewBag.Mode = "date";
                ViewBag.Placeholder = "dd.MM.yyyy";
                ViewBag.InitialValue = string.Empty;
                ViewBag.NoFuture = true;
            }
            @await Html.PartialAsync("_DateTimeControl")
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-dark" type="submit">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
