@model IReadOnlyList<Vehicle>
@{
    ViewData["Title"] = "Vozila";
}

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Početna</a>
    <span>/</span>
    <span>Vozila</span>
</nav>

<section class="page-header">
    <div>
        <h1>Vozila</h1>
        <p class="mb-0">Pregled vozila koja se servisiraju u radionici.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">+ Novo vozilo</a>
</section>

<div class="search-container mb-3">
    <div class="input-group">
        <input type="text"
               id="searchInput"
               class="form-control"
               placeholder="Pretraži vozila (registracija, marka, model, vlasnik)..."
               data-endpoint="/Vehicles/api/search" />
        <span class="input-group-text"><i class="bi bi-search"></i></span>
    </div>
    <div id="searchResults" style="display: none;"></div>
</div>

<div id="tableContainer" class="table-responsive">
    <table class="table paper-table">
        <thead>
            <tr>
                <th>Registracija</th>
                <th>Proizvodac / Model</th>
                <th>Godina</th>
                <th>Gorivo</th>
                <th>Vlasnik</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vehicle in Model)
            {
                <tr>
                    <td>@vehicle.LicensePlate</td>
                    <td>@vehicle.Manufacturer @vehicle.Model</td>
                    <td>@vehicle.Year</td>
                    <td>@vehicle.FuelType</td>
                    <td>
                        <a asp-controller="Customers" asp-action="Details" asp-route-id="@vehicle.CustomerId">
                            @vehicle.Owner?.FirstName @vehicle.Owner?.LastName
                        </a>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@vehicle.Id" class="btn-link">Detalji</a>
                        <a asp-action="Edit" asp-route-id="@vehicle.Id" class="btn-link">Uredi</a>
                        <a asp-action="Delete" asp-route-id="@vehicle.Id" class="btn-link text-danger">Obriši</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
