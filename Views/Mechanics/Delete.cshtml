@model Mechanic
@{
    ViewData["Title"] = "Obriši mehaničara";
}

<section class="page-header">
    <h1>Obriši mehaničara</h1>
</section>

<div class="paper-card border-danger">
    <p><strong>@Model.FirstName @Model.LastName</strong></p>
    <p>@Model.Specialty</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Obriši</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark btn-cancel">Odustani</a>
    </form>
</div>
