@model OrderLine
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="paper-card">
        <div class="mb-3">
            <label>Radni nalog</label>
            @{
                ViewBag.InputId = "ServiceOrderId";
                ViewBag.InputName = "ServiceOrderId";
                ViewBag.DisplayId = "ServiceOrderDisplay";
                ViewBag.DisplayName = "Odaberi radni nalog...";
                ViewBag.SearchEndpoint = "/ServiceOrders/Search";
                ViewBag.InitialValue = "";
                ViewBag.InitialLabel = "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label>Usluga</label>
            @{
                ViewBag.InputId = "ServiceItemId";
                ViewBag.InputName = "ServiceItemId";
                ViewBag.DisplayId = "ServiceItemDisplay";
                ViewBag.DisplayName = "Odaberi uslugu...";
                ViewBag.SearchEndpoint = "/ServiceItems/Search";
                ViewBag.InitialValue = "";
                ViewBag.InitialLabel = "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="UnitPrice"></label>
            <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
        </div>
        <div class="mb-3">
            <label asp-for="PartCost"></label>
            <input asp-for="PartCost" class="form-control" type="number" step="0.01" />
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
