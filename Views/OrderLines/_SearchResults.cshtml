@model IReadOnlyList<OrderLine>

<div class="table-responsive">
    <table class="table paper-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nalog</th>
                <th>Usluga</th>
                <th>Kolicina</th>
                <th>Jed. cijena</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Nema rezultata pretrage</td>
                </tr>
            }
            else
            {
                foreach (var line in Model)
                {
                    <tr>
                        <td>@line.Id</td>
                        <td><a asp-controller="ServiceOrders" asp-action="Details" asp-route-id="@line.ServiceOrderId">@line.ServiceOrder?.OrderNumber</a></td>
                        <td><a asp-controller="ServiceItems" asp-action="Details" asp-route-id="@line.ServiceItemId">@line.ServiceItem?.Name</a></td>
                        <td>@line.Quantity</td>
                        <td>@line.UnitPrice.ToString("0.00") EUR</td>
                        <td><a asp-action="Details" asp-route-id="@line.Id">Detalji</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>