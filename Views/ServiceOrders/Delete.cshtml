@model ServiceOrder
<section class="page-header">
    <h1>Obriši radni nalog</h1>
</section>

<div class="paper-card border-danger">
    <p><strong>@Model.OrderNumber</strong></p>
    <p>Zakazano: @Model.ScheduledAt.ToString("dd.MM.yyyy HH:mm")</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger">Obriši</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">Odustani</a>
    </form>
</div>
