@model ServiceItem
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="BasePrice"></label>
            <input asp-for="BasePrice" class="form-control" type="number" step="0.01" />
        </div>
        <div class="mb-3">
            <label asp-for="EstimatedDurationMinutes"></label>
            <input asp-for="EstimatedDurationMinutes" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="RequiresParts"></label>
            <input asp-for="RequiresParts" type="checkbox" />
        </div>
        <div class="mb-3">
            <label>Kategorija</label>
            <select asp-for="ServiceCategoryId" class="form-control">
                <option value="">-- odaberi kategoriju --</option>
                @foreach (var c in (IEnumerable<ServiceCategory>)ViewBag.ServiceCategories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-dark btn-cancel">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
