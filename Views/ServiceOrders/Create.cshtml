@model ServiceOrder
@{
    ViewData["Title"] = "Novi radni nalog";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="OrderNumber"></label>
            <input asp-for="OrderNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ScheduledAt"></label>
            <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="DiscountPercent"></label>
            <input asp-for="DiscountPercent" type="number" step="0.01" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Notes"></label>
            <textarea asp-for="Notes" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label>Kupac</label>
            <select asp-for="CustomerId" class="form-control">
                <option value="">-- odaberi kupca --</option>
                @foreach (var c in (IEnumerable<Customer>)ViewBag.Customers) { <option value="@c.Id">@c.FirstName @c.LastName</option> }
            </select>
        </div>
        <div class="mb-3">
            <label>Vozilo</label>
            <select asp-for="VehicleId" class="form-control">
                <option value="">-- odaberi vozilo --</option>
                @foreach (var v in (IEnumerable<Vehicle>)ViewBag.Vehicles) { <option value="@v.Id">@v.Manufacturer @v.Model (@v.LicensePlate)</option> }
            </select>
        </div>
        <div class="mb-3">
            <label>Mehaničar</label>
            <select asp-for="MechanicId" class="form-control">
                <option value="">-- odaberi mehaničara --</option>
                @foreach (var m in (IEnumerable<Mechanic>)ViewBag.Mechanics) { <option value="@m.Id">@m.FirstName @m.LastName</option> }
            </select>
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
