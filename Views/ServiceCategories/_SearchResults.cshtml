@model IReadOnlyList<ServiceCategory>

<div class="table-responsive">
    <table class="table paper-table">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Opis</th>
                <th>Broj usluga</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">Nema rezultata pretrage</td>
                </tr>
            }
            else
            {
                foreach (var category in Model)
                {
                    <tr>
                        <td>@category.Name</td>
                        <td>@category.Description</td>
                        <td>@category.Services.Count</td>
                        <td><a asp-action="Details" asp-route-id="@category.Id">Detalji</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>