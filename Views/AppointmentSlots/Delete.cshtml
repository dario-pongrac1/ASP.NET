@model AppointmentSlot
<section class="page-header">
    <h1>Obriši termin</h1>
</section>

<div class="paper-card border-danger">
    <p><strong>@Model.StartAt.ToString("dd.MM.yyyy HH:mm") - @Model.EndAt.ToString("dd.MM.yyyy HH:mm")</strong></p>
    <p>Mehaničar: @Model.Mechanic?.FirstName @Model.Mechanic?.LastName</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger">Obriši</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">Odustani</a>
    </form>
</div>
