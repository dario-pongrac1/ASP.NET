@model IReadOnlyList<Customer>
@{
    ViewData["Title"] = "Kupci";
}

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Pocetna</a>
    <span>/</span>
    <span>Kupci</span>
</nav>

<section class="page-header">
    <div>
        <h1>Kupci</h1>
        <p class="mb-0">Svi registrirani korisnici radionice.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">+ Novi kupac</a>
</section>

<div class="table-responsive">
    <table class="table paper-table">
        <thead>
            <tr>
                <th>Ime</th>
                <th>Telefon</th>
                <th>Email</th>
                <th>Vozila</th>
                <th>Nalozi</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.FirstName @customer.LastName</td>
                    <td>@customer.PhoneNumber</td>
                    <td>@customer.Email</td>
                    <td>@customer.Vehicles.Count</td>
                    <td>@customer.ServiceOrders.Count</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@customer.Id" class="btn-link">Detalji</a>
                        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn-link">Uredi</a>
                        <a asp-action="Delete" asp-route-id="@customer.Id" class="btn-link text-danger">Obriši</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
