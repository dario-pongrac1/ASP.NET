@model Vehicle
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="Vin"></label>
            <input asp-for="Vin" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="LicensePlate"></label>
            <input asp-for="LicensePlate" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Manufacturer"></label>
            <input asp-for="Manufacturer" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Model"></label>
            <input asp-for="Model" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Year"></label>
            <input asp-for="Year" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="MileageKm"></label>
            <input asp-for="MileageKm" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="FuelType"></label>
            <select asp-for="FuelType" class="form-control" asp-items="Html.GetEnumSelectList(typeof(lab_1.Models.Enums.VehicleFuelType))"></select>
        </div>
        <div class="mb-3">
            <label asp-for="LastServiceDate"></label>
            @{
                ViewBag.InputId = "LastServiceDate";
                ViewBag.InputName = "LastServiceDate";
                ViewBag.Mode = "date";
                ViewBag.Placeholder = "dd.MM.yyyy";
                ViewBag.InitialValue = Model.LastServiceDate == default
                    ? string.Empty
                    : Model.LastServiceDate.ToString("yyyy-MM-dd");
                ViewBag.NoFuture = true;
            }
            @await Html.PartialAsync("_DateTimeControl")
        </div>
        <div class="mb-3">
            <label>Vlasnik</label>
            @{
                var customer = Model.CustomerId > 0 ? ((IEnumerable<Customer>)ViewBag.Customers)?.FirstOrDefault(c => c.Id == Model.CustomerId) : null;
                ViewBag.InputId = "CustomerId";
                ViewBag.InputName = "CustomerId";
                ViewBag.DisplayId = "CustomerDisplay";
                ViewBag.DisplayName = "Odaberi kupca...";
                ViewBag.SearchEndpoint = "/Customers/Search";
                ViewBag.InitialValue = customer?.Id ?? 0;
                ViewBag.InitialLabel = customer != null ? $"{customer.FirstName} {customer.LastName}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark" type="submit">Spremi promjene</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
