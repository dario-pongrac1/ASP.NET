@model AppointmentSlot
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="StartAt"></label>
            @{
                ViewBag.InputId = "StartAt";
                ViewBag.InputName = "StartAt";
                ViewBag.Mode = "datetime";
                ViewBag.Placeholder = "dd.MM.yyyy HH:mm";
                ViewBag.InitialValue = Model.StartAt == default
                    ? string.Empty
                    : Model.StartAt.ToString("yyyy-MM-ddTHH:mm");
                ViewBag.NoPast = true;
            }
            @await Html.PartialAsync("_DateTimeControl")
        </div>
        <div class="mb-3">
            <label asp-for="EndAt"></label>
            @{
                ViewBag.InputId = "EndAt";
                ViewBag.InputName = "EndAt";
                ViewBag.Mode = "datetime";
                ViewBag.Placeholder = "dd.MM.yyyy HH:mm";
                ViewBag.InitialValue = Model.EndAt == default
                    ? string.Empty
                    : Model.EndAt.ToString("yyyy-MM-ddTHH:mm");
                ViewBag.CompareTarget = "#StartAt";
                ViewBag.CompareMode = "after";
            }
            @await Html.PartialAsync("_DateTimeControl")
        </div>
        <div class="mb-3">
            <label>Mehaničar</label>
            @{
                var mechanic = Model.MechanicId > 0 ? ((IEnumerable<Mechanic>)ViewBag.Mechanics)?.FirstOrDefault(m => m.Id == Model.MechanicId) : null;
                ViewBag.InputId = "MechanicId";
                ViewBag.InputName = "MechanicId";
                ViewBag.DisplayId = "MechanicDisplay";
                ViewBag.DisplayName = "Odaberi mehaničara...";
                ViewBag.SearchEndpoint = "/Mechanics/Search";
                ViewBag.InitialValue = mechanic?.Id ?? 0;
                ViewBag.InitialLabel = mechanic != null ? $"{mechanic.FirstName} {mechanic.LastName}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label>Radni nalog (opcionalno)</label>
            @{
                var serviceOrder = Model.ServiceOrderId > 0 ? ((IEnumerable<ServiceOrder>)ViewBag.ServiceOrders)?.FirstOrDefault(o => o.Id == Model.ServiceOrderId) : null;
                ViewBag.InputId = "ServiceOrderId";
                ViewBag.InputName = "ServiceOrderId";
                ViewBag.DisplayId = "ServiceOrderDisplay";
                ViewBag.DisplayName = "Odaberi radni nalog...";
                ViewBag.SearchEndpoint = "/ServiceOrders/Search";
                ViewBag.InitialValue = serviceOrder?.Id ?? 0;
                ViewBag.InitialLabel = serviceOrder != null ? $"{serviceOrder.OrderNumber}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label asp-for="IsReserved"></label>
            <input asp-for="IsReserved" type="checkbox" />
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi promjene</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
