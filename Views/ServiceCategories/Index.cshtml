@model IReadOnlyList<ServiceCategory>
@{
    ViewData["Title"] = "Kategorije usluga";
}

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Početna</a>
    <span>/</span>
    <span>Kategorije</span>
</nav>

<section class="page-header">
    <div>
        <h1>Kategorije usluga</h1>
        <p class="mb-0">Klasifikacija usluga radionice.</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">+ Nova kategorija</a>
</section>

<div class="search-container mb-3">
    <div class="input-group">
        <input type="text"
               id="searchInput"
               class="form-control"
               placeholder="Pretraži kategorije (naziv, opis)..."
               data-endpoint="/ServiceCategories/api/search" />
        <span class="input-group-text"><i class="bi bi-search"></i></span>
    </div>
    <div id="searchResults" style="display: none;"></div>
</div>

<div id="tableContainer" class="table-responsive">
    <table class="table paper-table">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Opis</th>
                <th>Broj usluga</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.Description</td>
                    <td>@category.Services.Count</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@category.Id" class="btn-link">Detalji</a>
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn-link">Uredi</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn-link text-danger">Obriši</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
