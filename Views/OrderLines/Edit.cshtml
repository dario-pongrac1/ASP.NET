@model OrderLine
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="paper-card">
        <div class="mb-3">
            <label>Radni nalog</label>
            @{
                var serviceOrder = Model.ServiceOrderId > 0 ? ((IEnumerable<ServiceOrder>)ViewBag.ServiceOrders)?.FirstOrDefault(o => o.Id == Model.ServiceOrderId) : null;
                ViewBag.InputId = "ServiceOrderId";
                ViewBag.InputName = "ServiceOrderId";
                ViewBag.DisplayId = "ServiceOrderDisplay";
                ViewBag.DisplayName = "Odaberi radni nalog...";
                ViewBag.SearchEndpoint = "/ServiceOrders/Search";
                ViewBag.InitialValue = serviceOrder?.Id ?? 0;
                ViewBag.InitialLabel = serviceOrder != null ? $"{serviceOrder.OrderNumber}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label>Usluga</label>
            @{
                var serviceItem = Model.ServiceItemId > 0 ? ((IEnumerable<ServiceItem>)ViewBag.ServiceItems)?.FirstOrDefault(s => s.Id == Model.ServiceItemId) : null;
                ViewBag.InputId = "ServiceItemId";
                ViewBag.InputName = "ServiceItemId";
                ViewBag.DisplayId = "ServiceItemDisplay";
                ViewBag.DisplayName = "Odaberi uslugu...";
                ViewBag.SearchEndpoint = "/ServiceItems/Search";
                ViewBag.InitialValue = serviceItem?.Id ?? 0;
                ViewBag.InitialLabel = serviceItem != null ? $"{serviceItem.Name}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity" class="form-control" type="number" />
        </div>
        <div class="mb-3">
            <label asp-for="UnitPrice"></label>
            <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
        </div>
        <div class="mb-3">
            <label asp-for="PartCost"></label>
            <input asp-for="PartCost" class="form-control" type="number" step="0.01" />
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi promjene</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark btn-cancel">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
