@model ServiceOrder
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="paper-card">
        <div class="mb-3">
            <label asp-for="OrderNumber"></label>
            <input asp-for="OrderNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ScheduledAt"></label>
            @{
                ViewBag.InputId = "ScheduledAt";
                ViewBag.InputName = "ScheduledAt";
                ViewBag.Mode = "datetime";
                ViewBag.Placeholder = "dd.MM.yyyy HH:mm";
                ViewBag.InitialValue = Model.ScheduledAt == default
                    ? string.Empty
                    : Model.ScheduledAt.ToString("yyyy-MM-ddTHH:mm");
                ViewBag.NoPast = true;
            }
            @await Html.PartialAsync("_DateTimeControl")
        </div>
        <div class="mb-3">
            <label asp-for="DiscountPercent"></label>
            <input asp-for="DiscountPercent" type="number" step="0.01" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Notes"></label>
            <textarea asp-for="Notes" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label>Kupac</label>
            @{
                var customer = Model.CustomerId > 0 ? ((IEnumerable<Customer>)ViewBag.Customers)?.FirstOrDefault(c => c.Id == Model.CustomerId) : null;
                ViewBag.InputId = "CustomerId";
                ViewBag.InputName = "CustomerId";
                ViewBag.DisplayId = "CustomerDisplay";
                ViewBag.DisplayName = "Odaberi kupca...";
                ViewBag.SearchEndpoint = "/Customers/Search";
                ViewBag.InitialValue = customer?.Id ?? 0;
                ViewBag.InitialLabel = customer != null ? $"{customer.FirstName} {customer.LastName}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label>Vozilo</label>
            @{
                var vehicle = Model.VehicleId > 0 ? ((IEnumerable<Vehicle>)ViewBag.Vehicles)?.FirstOrDefault(v => v.Id == Model.VehicleId) : null;
                ViewBag.InputId = "VehicleId";
                ViewBag.InputName = "VehicleId";
                ViewBag.DisplayId = "VehicleDisplay";
                ViewBag.DisplayName = "Odaberi vozilo...";
                ViewBag.SearchEndpoint = "/Vehicles/Search";
                ViewBag.InitialValue = vehicle?.Id ?? 0;
                ViewBag.InitialLabel = vehicle != null ? $"{vehicle.Manufacturer} {vehicle.Model} ({vehicle.LicensePlate})" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
        <div class="mb-3">
            <label>Mehaničar</label>
            @{
                var mechanic = Model.MechanicId > 0 ? ((IEnumerable<Mechanic>)ViewBag.Mechanics)?.FirstOrDefault(m => m.Id == Model.MechanicId) : null;
                ViewBag.InputId = "MechanicId";
                ViewBag.InputName = "MechanicId";
                ViewBag.DisplayId = "MechanicDisplay";
                ViewBag.DisplayName = "Odaberi mehaničara...";
                ViewBag.SearchEndpoint = "/Mechanics/Search";
                ViewBag.InitialValue = mechanic?.Id ?? 0;
                ViewBag.InitialLabel = mechanic != null ? $"{mechanic.FirstName} {mechanic.LastName}" : "";
            }
            @await Html.PartialAsync("_AutocompleteDropdown")
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-dark">Spremi promjene</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark">Odustani</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
